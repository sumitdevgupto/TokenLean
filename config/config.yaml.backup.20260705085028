groups:
  G1_compression:
    enabled: false
    min_tokens_to_compress: 200
    compression_ratio_target: 0.5
    force_reserve_digit: true
    sidecar_url: http://llmlingua:8080/compress
    compress_user_messages: false
    layered_composition_enabled: true
    layers:
      base: You are a helpful AI assistant.
      role: You specialize in {domain}.
      task: Your current task is to {task_description}.
      dynamic: 'Additional context: {context}'
    selective_context_enabled: true
    selective_context_max_tokens: 4000
    build_time_compression: true
    min_chars_to_compress: 100
    reduction_threshold: 0.95
    compress_system_prompt: false
    kompress_enabled: true
    kompress_model: microsoft/Kompress-v2-base
    kompress_max_new_tokens: 256
  G2_template_registry:
    enabled: false
    budget:
      truncate_enabled: true
      truncate_strategy: tail_system
      min_keep_user_turns: 1
    budgets:
      customer-support-classifier:
        version: '2.1'
        system_prompt_max: 400
        total_input_max: 800
        output_max: 150
        author: platform-team
        description: Classifies customer support tickets
      ds1-enterprise-support-policy:
        version: '1.0'
        system_prompt_max: 4000
        total_input_max: 8000
        output_max: 400
        author: platform-team
        description: DS1 enterprise support policy/system prompt (G20 target)
        prompt: You are an enterprise support assistant. Please note that every response
          must follow the escalation policy described below. In order to maintain
          consistency, make sure to verify the customer's account tier before answering.
          It is important to confirm the ticket category (billing, technical, or account)
          at the start of the conversation. Due to the fact that enterprise customers
          have a 1-hour SLA, ensure that you flag any unresolved issue older than
          45 minutes for escalation. With regard to billing disputes, at this point
          in time you should not promise refunds without checking the account ledger
          first. In the event that a customer reports a security issue, escalate immediately
          and do not attempt further troubleshooting. In addition to the escalation
          policy, please note that you must always summarize the resolution in two
          sentences at the end of the ticket. For the purpose of analytics, make sure
          to tag every ticket with its category and urgency level before closing it.
          Ensure that you never share internal infrastructure details with customers.
          In order to keep response times low, due to the fact that enterprise customers
          expect a fast turnaround, avoid lengthy explanations unless the customer
          explicitly asks for more detail. With regard to tone, please note that you
          should remain calm and professional even if the customer is frustrated.
          At this point in time, all tickets must be logged with a ticket ID before
          responding. In the event that the ticket ID is missing, ask the customer
          for it once, politely. In addition to logging the ticket ID, make sure to
          record the account tier and urgency level in the ticket metadata.
      ds2-rag-synthesis:
        version: '1.0'
        system_prompt_max: 2000
        total_input_max: 6000
        output_max: 400
        author: platform-team
        description: DS2 RAG-synthesis answer template (G20 target)
        prompt: You are a retrieval-augmented assistant. Please note that you must
          only answer using the retrieved context provided below; do not rely on outside
          knowledge. In order to produce a grounded answer, make sure to cite the
          specific document chunk that supports each claim. It is important to acknowledge
          when the retrieved context does not contain enough information to answer
          the question. Due to the fact that retrieved chunks may be incomplete, ensure
          that you do not fabricate details that are not present in the context. With
          regard to formatting, present the answer as a short paragraph followed by
          a bulleted list of supporting citations. In the event that multiple chunks
          contradict each other, note the discrepancy explicitly rather than picking
          one arbitrarily. In addition to citing sources, at this point in time you
          should also note the confidence level of your answer as high, medium, or
          low. For the purpose of traceability, please note that every citation must
          include the document title and chunk index.
    deprecation_warn_days: 30
    template_history_ttl_days: 90
    max_history_per_version: 1000
  G3_doc_pipeline:
    enabled: true
    chunk_size_tokens: 400
    chunk_overlap_tokens: 50
    sparse_model: Qdrant/bm25
    dense_model: all-MiniLM-L6-v2
    rag_fallback:
      enabled: true
      collection: rag_docs
      top_k: 5
