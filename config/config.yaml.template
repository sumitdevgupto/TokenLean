      gpt-4-turbo: 4096
      gpt-4: 8192
      gpt-3.5-turbo: 4096
      claude-3-opus: 4096
      claude-3-sonnet: 4096
      claude-3-haiku: 4096
      claude-3.5-sonnet: 8192
      claude-3.5-haiku: 8192
      claude-4-sonnet: 16384
      gemini-2.5-flash: 8192
      gemini-2.5-pro: 8192
      mistral-large: 8192
      mistral-small: 8192
