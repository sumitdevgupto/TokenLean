    max_tokens_feedback_loop: true
    max_tokens_auto_tighten: true
    tighten_quantile: 0.95
    tighten_multiplier: 1.2
    max_tokens_history_ttl_days: 7
    default_model_max_tokens: 4096
    model_max_tokens:
      gpt-4o: 16384
