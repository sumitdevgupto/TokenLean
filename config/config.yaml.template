  G23_streaming_compression:
    enabled: true
    min_repeat: 3
    ngram_size: 5
  G28_ccr:
    # Off by default: CCR replaces large content blocks with a [CCR:ref] token that
    # the model resolves via the headroom_retrieve MCP tool. That only works for a
    # client running an agent loop that calls the tool and re-sends the result; in a
    # plain pass-through chat completion the model can't resolve the reference and
    # answers from a gutted context. Enable only for cooperating agent clients.
    enabled: false
    min_tokens: 300                # replace string content blocks at/above this token count
    ttl_seconds: 86400
    expose_mcp_tools: true
    compress_system_prompt: false  # keep false — the system instruction must stay verbatim
                                   # (the model can't resolve a CCR ref for it in pass-through)
  G27_multimodal:
    enabled: true
    min_bytes: 4096
    quality: 75
    provider: null                   # optional Headroom provider hint; null = auto-detect from the active adapter
  G24_adaptive_bypass:
    enabled: true
    rules_file: config/adaptive_bypass_rules.yaml
  G25_adaptive_reasoning:
    enabled: true
    effort_floor: low
    effort_ceiling: high
    extra_reasoning_prefixes: []
  # ── Trust & Safety (G29 PII redaction, G30 injection guardrails) ─────────────
  # Both run early and UNCONDITIONALLY — inserted after G24 and before the G04/G05
  # gate, outside the skip_groups loops — so G24 adaptive-bypass can never disable
  # them, bypass/cache traffic is still covered, and redaction precedes every
  # content-persisting stage (G05 key/embedding, G07 RAG, G10 memory, G28 CCR).
  # Defaults are NON-MUTATING (mode: flag) so the shipped config is safe and its
  # token accounting is unchanged. Override per-tenant under
  # tenants.<id>.groups.G29_pii_redaction / .G30_guardrails.
  G30_guardrails:
    enabled: true
    mode: flag                 # allow | flag | block. flag = detect + record + pass
                               # (default, non-mutating). block = refuse with a
                               # content-filter 200. allow = passthrough (no scan).
    threshold: 0.5             # minimum rule severity to fire (raise for higher confidence)
    scan_roles: [user]         # only untrusted (user) content is scanned by default
    metrics_enabled: true
    extra_rules: []            # [[id, category, severity, regex], …] operator/managed additions
    # block_message: "This request was blocked by the safety guardrails."
    scan_response: false       # opt-in: also scan the MODEL'S OUTPUT for injection /
                               # jailbreak content (a model echoing an attack payload or
                               # emitting unsafe instructions). Default off = unchanged.
    response_mode: flag        # flag | block (when scan_response). flag = detect + record;
                               # block = withhold the unsafe answer with a content-filter 200.
    # response_block_message: "The response was withheld by the safety guardrails."
  G29_pii_redaction:
    enabled: true
    mode: flag                 # off | flag | mask | block. flag = detect + record only
                               # (default, non-mutating). mask = replace in place;
                               # block = refuse a request that contains PII.
    reversible: true           # mask mode: the model sees numbered placeholders and the
                               # non-streaming response restores them for the data owner.
    scan_roles: [user, assistant, tool]   # roles scanned (system prompt left untouched)
    entities: []               # empty = all built-in PII; or narrow, e.g. [EMAIL, CREDIT_CARD].
                               # PHI is opt-in: add health entities explicitly
                               # ([DEA, NPI, MRN, ICD10]) or the `phi` shortcut token.
    phi: false                 # true = ALSO scan health identifiers (DEA/NPI/MRN/ICD-10,
                               # precision-biased: DEA/NPI checksum-gated, MRN/ICD-10 need a
                               # medical context cue). Default off — PII-only, unchanged.
    use_presidio: false        # optional higher-recall backend (needs presidio-analyzer)
    metrics_enabled: true
    # block_message: "This request was blocked because it contained personal data."
  # ── Context-Trust (G31 indirect prompt-injection defence) ────────────────────
  # G30 scans the untrusted USER prompt; G31 scans content INJECTED by retrieval
  # (G07) and memory (G10) into system/tool roles — the indirect / RAG injection
  # path that G30 (running earlier) cannot see. Runs after the G07/G10 stages and
  # is NON-BYPASSABLE (not gated by skip_groups). Default mode: flag (non-mutating).
  G31_context_trust:
    enabled: true
    mode: flag                 # allow | flag | block | strip. flag = detect + record +
                               # pass (default, non-mutating). block = content-filter 200.
                               # strip = drop the poisoned injected message/part & continue.
                               # allow = passthrough (no scan).
    threshold: 0.5             # minimum rule severity to fire
    scan_roles: [system, tool] # roles that retrieval/memory inject into (user is G30's job)
    metrics_enabled: true
    extra_rules: []            # [[id, category, severity, regex], …] managed-feed additions
    # block_message: "Retrieved context contained a prompt-injection attempt."
    # ── PII pass over retrieved context (opt-in; same engine as G29) ──
    pii_mode: off              # off (default) | flag | mask | block. Scans the SAME
                               # system/tool spans for PII (email/SSN/card/phone/IPv4 +
                               # optional PHI). mask = irreversible [EMAIL] placeholders
                               # (retrieved PII is never restored). block = content-filter 200.
    # pii_entities: []         # subset of EMAIL/US_SSN/CREDIT_CARD/PHONE/IP_ADDRESS (+ phi);
                               # empty/unset → the PII default set. A `phi` token expands to
                               # the PHI set (DEA/NPI/MRN/ICD10).
    # pii_phi: false           # convenience: also scan the PHI set
    # pii_use_presidio: false  # augment regex with Presidio recognisers when installed
    # pii_block_message: "Retrieved context contained personal data."

# ── Agentic Learning Loop (F1) — [Enterprise] managed, opt-in ──────────────────
# A managed background job (wired only by the commercial app) that periodically mines
# the OSS-core usage_events ledger and, for each (tenant, routed_model), finds
# savings-optimisation groups that run but realise ≈no tokens — then writes per-tenant
# adaptive-bypass rules into the SAME artifact G24 hot-reloads
# (config/adaptive_bypass_rules.yaml + the GCS mirror on GCP). Within one G24 reload
# (~60s) the proxy stops paying for that group for that cohort — zero engineer effort.
# No-op in OSS (the miner module ships only in the commercial image). Default OFF.
learning:
  signal_miner:
    enabled: false                     # master switch (managed/opt-in). false → total no-op.
    interval_seconds: 900              # minutes between mining passes (min 60). Hot-reloadable.
    window_hours: 168                  # lookback over usage_events (default 7 days)
    min_samples: 200                   # ignore a cohort thinner than this (noise floor)
    max_avg_saving_per_run: 5.0        # tokens/run at/below which a group is "unproductive"
    rules_file: config/adaptive_bypass_rules.yaml   # MUST match groups.G24_adaptive_bypass.rules_file
    # Groups the loop may auto-skip. Conservative default = prompt-shaping optimisations whose
    # absence only forfeits savings (never correctness/safety). A hard denylist (cache G05,
    # routing G06, rate-limit G00, observability G18, trust&safety G29/G30/G31) is enforced in
    # code regardless of what is listed here.
    skippable_groups: [G01, G20, G22]
    # Per-tenant overrides (Gate 2): tenants.<ID>.learning.signal_miner.{min_samples,
    # max_avg_saving_per_run, skippable_groups, ...} take precedence for that tenant's cohorts.

# ── Intent-Based Multi-Agent Orchestration (F2) — engine OSS, console [Enterprise] ──
# One proxy endpoint fans a request to the right DOWNSTREAM AGENT by semantic intent,
# instead of always calling the same LLM. An agent is any OpenAI-compatible chat endpoint
# (a service you run). When the last user turn matches an agent's `match` keywords, the
# request is forwarded to that agent's URL and its answer is served (billing + response
# groups still fire); no match → the normal LLM path runs. Default OFF / no-op (no agents).
# The managed registry console + routing-decision audit + ML intent classifier are the
# [Enterprise] layer — https://tokenlean.cbeyond.cloud/. Per-tenant override:
# tenants.<ID>.orchestration.* (a tenant's `agents` list REPLACES the global one — never
# merges — so agents never leak across tenants).
orchestration:
  enabled: false                     # master switch. false → no-op, byte-identical path.
  confidence_threshold: 1            # min matched keywords to dispatch (else fall back to LLM)
  agents: []                         # [] = disabled. Example entry:
    # - id: billing
    #   description: "Billing, invoices, refunds, charges"   # for the managed ML classifier
    #   url: http://billing-agent:8000/v1                    # OpenAI-compatible endpoint
    #   match: [refund, invoice, billing, charge, payment]   # heuristic intent keywords
    #   model: gpt-4o-mini            # optional: model string sent to the agent (default: requested)
    #   api_key_env: BILLING_AGENT_KEY # optional: env var holding the agent's API key
    #   max_tokens: 1024              # optional: per-agent output budget (governance)
    #   timeout_seconds: 60           # optional: dispatch timeout before fallback
