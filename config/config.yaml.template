params_dir: config/params
proxy:
  port: 4000
  api_key_header: Authorization
  log_level: INFO
  cors_origins:
  - '*'
  default_model: gpt-4o-mini
  fallback_request_model: gpt-4o-mini
  # Provider used when a model matches no providers[].model_prefixes (replaces the old
  # hardcoded "openai" fallback). Set to whichever provider your default_model belongs to.
  default_provider: openai
  allow_user_id_header_override: true
  allowed_user_id_headers:
  - pitch-baseline
  - pitch-optimized
  - test-*
  - '*-pitch'
  - '*-user'
services:
  llmlingua_url: http://llmlingua-svc:8080/compress
  qdrant_url: http://qdrant:6333
  tika_url: http://tika-svc:9998
  routellm_url: http://routellm-svc:8081
  langfuse_host: http://langfuse-svc:3000
  mem0_url: ''
  zep_url: ''
savings:
  chars_per_token: 4
  per_message_overhead: 4
  per_tool_overhead: 4
  # B2 / P11 — non-GPT models (Claude/Gemini/Mistral/…) use cl100k_base tiktoken locally
  # for a closer-than-char/4 ingress baseline (no provider API call). Approximate but better
  # than char/4; affects the savings-% estimate only — billed tokens come from provider usage.
  non_gpt_tiktoken_fallback: true
rate_limit:
  enabled: true
  default:
    requests_per_minute: 60
    requests_per_hour: 1000
  per_user:
    user-01:
      requests_per_minute: 2
      requests_per_hour: 120
  per_team:
    team-alpha:
      requests_per_minute: 20
      requests_per_hour: 1200
providers:
- name: openai
  api_base: https://api.openai.com/v1
  models:
  - gpt-4o-mini
  - gpt-4o
  - o1
  - o3
  - gpt-4-5
  model_prefixes:
  - gpt
  - o1
  - o3
  - text-
  - davinci
  - babbage
  - curie
  - ada
  tiktoken_prefixes:
  - gpt
  - o1
  - o3
  - text-
  - davinci
  - babbage
  - curie
  - ada
- name: anthropic
  api_base: https://api.anthropic.com/v1
  models:
  - claude-haiku-4-5
  - claude-sonnet-4-5
  - claude-opus-4
  model_prefixes:
  - claude
# ── Additional first-class providers (each has a dedicated adapter) ─────────────────
# These resolve to their adapter class; the litellm namespace is baked into the adapter,
# so only model_prefixes are required. Set the matching LLM_KEY_<NAME> / llm-key-<name>.
# models[] lead with each provider's cheapest model (verify exact IDs against the provider).
- name: gemini
  models:
  - gemini-2.5-flash-lite      # cheapest Gemini
  - gemini-2.5-flash
  model_prefixes:
  - gemini
- name: mistral
  models:
  - ministral-3b-latest        # cheapest Mistral
  - mistral-small-latest
  model_prefixes:
  - mistral
  - mixtral
  - ministral
  - magistral
  - codestral
  - pixtral
- name: deepseek
  models:
  - deepseek-chat              # cheapest DeepSeek (deepseek-reasoner costs more)
  model_prefixes:
  - deepseek
- name: xai
  models:
  - grok-3-mini                # cheapest xAI
  model_prefixes:
  - grok
- name: cohere
  models:
  - command-r7b-12-2024        # cheapest Cohere
  - command-r
  model_prefixes:
  - command
  - cohere/
# Groq hosts many model families — route with an explicit "groq/" prefix to disambiguate.
- name: groq
  models:
  - groq/llama-3.1-8b-instant  # cheapest Groq
  model_prefixes:
  - groq/
# Azure shares OpenAI model names — route with an explicit "azure/<deployment>" and set
# api_base + api_version to your Azure resource. Key via LLM_KEY_AZURE.
- name: azure
  api_base: https://YOUR-RESOURCE.openai.azure.com
  api_version: '2024-10-21'
  # Azure model = your deployment name (azure/<deployment>); point it at a cheap deployment (e.g. gpt-4o-mini)
  model_prefixes:
  - azure/
# Bedrock uses AWS SigV4 (no bearer key) — creds from the environment / instance profile.
- name: bedrock
  aws_region: us-east-1
  models:
  - bedrock/amazon.nova-micro-v1:0   # cheapest Bedrock (Amazon Nova Micro)
  model_prefixes:
  - bedrock/
  - anthropic.
  - amazon.
  - meta.
  - mistral.
  - cohere.
  - us.anthropic.
# OpenRouter — aggregator exposing 200+ models behind one OpenAI-compatible API (config-only,
# generic adapter). Send models as "openrouter/<vendor>/<model>",
# e.g. openrouter/anthropic/claude-3.5-sonnet. Key via LLM_KEY_OPENROUTER.
- name: openrouter
  adapter: generic
  litellm_prefix: openrouter
  # Free models ($0). Verify the exact slug on each model's OpenRouter page (vendor/model:free).
  models:
  - openrouter/openai/gpt-oss-120b:free        # gpt-oss-120b (free)
  - openrouter/google/gemma-4-31b:free         # Gemma 4 31B (free)
  - openrouter/nvidia/nemotron-3-ultra:free    # Nemotron 3 Ultra (free)
  model_prefixes:
  - openrouter/
# OpenCode Zen — curated OpenAI-compatible gateway (config-only, generic adapter). Send models
# as "opencode/<model>" e.g. opencode/deepseek-v4-pro; the "opencode/" prefix is stripped before
# the upstream call. Key via LLM_KEY_OPENCODE.
- name: opencode
  adapter: generic
  openai_compatible: true
  api_base: https://opencode.ai/zen/v1
  route_prefix: opencode/
  # Free models ($0). Verify the exact slug on the OpenCode Zen dashboard.
  models:
  - opencode/mimo-v2.5             # MiMo V2.5 (free)
  - opencode/qwen3.6-plus          # Qwen3.6 Plus (free)
  - opencode/minimax-m3            # MiniMax M3 (free)
  model_prefixes:
  - opencode/
pricing:
  gpt-4o-mini:
    input: 0.00015
    output: 0.0006
  gpt-4o:
    input: 0.005
    output: 0.015
  gpt-4-5:
    input: 0.075
    output: 0.15
  o1:
    input: 0.015
    output: 0.06
  o3:
    input: 0.01
    output: 0.04
  claude-haiku:
    input: 0.00025
    output: 0.00125
  claude-sonnet:
    input: 0.003
    output: 0.015
  claude-opus:
    input: 0.015
    output: 0.075
  # New providers (USD per 1k tokens — verify against current price sheets; reporting only,
  # billing is per-request). Keys are substring-matched against the routed model name.
  gemini-2.5-flash:
    input: 0.0003
    output: 0.0025
  gemini-2.5-pro:
    input: 0.00125
    output: 0.01
  mistral-large:
    input: 0.002
    output: 0.006
  mistral-small:
    input: 0.0002
    output: 0.0006
  deepseek-reasoner:
    input: 0.00055
    output: 0.00219
  deepseek:
    input: 0.00027
    output: 0.0011
  grok:
    input: 0.003
    output: 0.015
  command-r-plus:
    input: 0.0025
    output: 0.01
  command-r:
    input: 0.00015
    output: 0.0006
  llama:
    input: 0.00059
    output: 0.00079
  # Bedrock-hosted model fragments (substring-matched against the routed model name, e.g.
  # "anthropic.claude-3-5-sonnet", "amazon.nova-pro"). Azure is per-deployment — add a row
  # keyed by your deployment name; otherwise it falls back to `default` below.
  claude-3-5-sonnet:
    input: 0.003
    output: 0.015
  claude-3-5-haiku:
    input: 0.0008
    output: 0.004
  claude-3-haiku:
    input: 0.00025
    output: 0.00125
  claude-3-opus:
    input: 0.015
    output: 0.075
  nova-pro:
    input: 0.0008
    output: 0.0032
  nova-lite:
    input: 0.00006
    output: 0.00024
  nova-micro:
    input: 0.000035
    output: 0.00014
  # OpenCode Zen (per 1k tokens; keyed by full opencode/<model> so longest-match wins over the
  # generic provider rows; free models = 0). Source: opencode.ai/zen — adjust as prices change.
  opencode/deepseek-v4-pro:
    input: 0.00174
    output: 0.00348
  opencode/glm-5.2:
    input: 0.0014
    output: 0.0044
  opencode/kimi-k2.6:
    input: 0.00095
    output: 0.004
  opencode/minimax-m2.7:
    input: 0.0003
    output: 0.0012
  # Free models = $0. OpenRouter free models all end in ":free" (one catch-all row); the
  # OpenCode Zen free models are listed explicitly.
  ':free':
    input: 0.0
    output: 0.0
  opencode/mimo-v2.5:
    input: 0.0
    output: 0.0
  opencode/qwen3.6-plus:
    input: 0.0
    output: 0.0
  opencode/minimax-m3:
    input: 0.0
    output: 0.0
  default:
    input: 0.005
    output: 0.015
groups:
  G1_compression:
    enabled: true
    min_tokens_to_compress: 200
    compression_ratio_target: 0.5
    force_reserve_digit: true        # preserve digit tokens (dates/IDs/amounts) so compression can't corrupt a tool argument
    sidecar_url: http://llmlingua-svc:8080/compress
    min_chars_to_compress: 100
    reduction_threshold: 0.95
    compress_user_messages: false
    compress_system_prompt: false
    layered_composition_enabled: true
    layers:
      base: You are a helpful AI assistant.
      role: You specialize in {domain}.
      task: Your current task is to {task_description}.
      dynamic: 'Additional context: {context}'
    selective_context_enabled: false
    selective_context_max_tokens: 4000
    build_time_compression: true
  G2_template_registry:
    enabled: true
    deprecation_warn_days: 30
    template_history_ttl_days: 90
    max_history_per_version: 1000
    budgets:
      customer-support-classifier:
        version: '2.1'
        system_prompt_max: 400
        total_input_max: 800
        output_max: 150
        author: platform-team
        description: Classifies customer support tickets
  G3_doc_pipeline:
    enabled: true
    chunk_size_tokens: 400
    chunk_overlap_tokens: 50
    sparse_model: Qdrant/bm25
    dense_model: all-MiniLM-L6-v2
    rag_fallback:
      enabled: true
      collection: rag_docs
      top_k: 5
      similarity_threshold: 0.85
      strategies:
      - strict_hybrid
      - relaxed_hybrid
      - dense_only
      - sparse_only
    fine_tuning:
      enabled: true
      min_docs: 100
      stability_days: 30
      auto_trigger: false
    tika_sidecar:
      enabled: false
      url: http://tika-svc:9998
  G4_bypass:
    enabled: true
    database_first: true
    default_confidence_threshold: 0.7
    keyword_weight: 0.4
    pattern_weight: 0.6
    rules:
    - name: order-status
      rule_id: bypass-002
      category: order
      confidence_threshold: 0.75
      keywords:
      - order status
      - track my order
      - where is my order
      patterns:
      - order\s*#?\s*\d+
      backend_url: ''
  G5_cache:
    enabled: true
    cache_scope: tenant
    l1_ttl_seconds: 3600
    l2_embedding_model: BAAI/bge-small-en-v1.5
    l2_similarity_threshold: 0.9
    l2_max_embed_chars: 2000
    semantic_skip_multiturn: true
    l2_ttl_seconds: 86400
    step_cache_enabled: true
    step_cache_ttl_seconds: 86400
    l3_enabled: true
    l3_similarity_threshold: 0.85
    auto_ttl_enabled: true
    auto_ttl_min_multiplier: 0.25
    auto_ttl_max_multiplier: 2.0
    temporal_replay_enabled: true
  G6_routing:
    enabled: true
    classifier: cascade
    cascade_execution: false
    tiers:
      simple:
      - gpt-4o-mini
      medium:
      - gpt-4o
      complex:
      - gpt-4-5
    judge_model: ${G06_JUDGE_MODEL:-}
    judge_timeout_ms: 2000
    cascade_confidence_threshold: 0.7
    max_escalation_cost_usd: 0.01
    routellm:
      url: http://routellm-svc:8081
      router: mf
      threshold: 0.11593
      timeout_ms: 500
      weak_model: gpt-4o-mini
      strong_model: gpt-4o
      model_map:
        weak: simple
        strong: complex
  G7_retrieval:
    enabled: true
    chunk_size_tokens: 256
    top_k: 3
    top_k_after_rerank: 1
    similarity_threshold: 0.85
    dense_model: all-MiniLM-L6-v2
    sparse_model: Qdrant/bm25
    reranker_model: cross-encoder/ms-marco-MiniLM-L-6-v2
    rrf_k: 60
    rrf_alpha: 0.5
    jit_retrieval_enabled: true
    use_pgvector_fallback: false
    max_chunk_tokens: 1000
    max_total_context_tokens: 4000
  G8_tools:
    enabled: true
    registry_path: gs://${CONFIG_GCS_BUCKET}/config/tool-registry.yaml
    max_tools_per_agent: 10
    registry_cache_ttl_seconds: 300
    mcp_manifest_cache_ttl_seconds: 300
    mcp_http_timeout_seconds: 10.0
    tool_usage_ttl_days: 90
    mcp_servers: null
    pruning:
      enabled: true
      inactivity_threshold_days: 30
      dry_run_first: true
      schedule: 0 2 * * *
  G9_context_schema:
    enabled: false
    use_instructor: true
    instructor_model: gpt-4o-mini
    instructor_timeout_ms: 3000
    instructor_fallback_to_heuristic: true
    prose_min_length_chars: 80
    prose_indicators:
    - customer
    - user
    - he
    - she
    - they
    - called
    - about
    - regarding
    - mentioned
    - requested
    - explained
    - told
    - said
    - asked
    schema_fields: null
  G10_memory:
    enabled: true
    memory_query_max_chars: 400
    sliding_window_turns: 6
    summary_model: gpt-4o-mini
    skills_enabled: false
    skills_qdrant_collection: agent_skills
    skills_top_k: 2
    skills_similarity_threshold: 0.7
    mem0_enabled: false
    zep_enabled: false
  G11_output:
    enabled: true
    enforce_max_tokens: true
    skip_max_tokens_for_reasoning: true
    default_max_tokens_multiplier: 2.0
    force_json_for_all: false
    provider_structured_output: true
    max_tokens_feedback_loop: true
    max_tokens_auto_tighten: true
    tighten_quantile: 0.95
    tighten_multiplier: 1.2
    max_tokens_history_ttl_days: 7
    default_model_max_tokens: 4096
    model_max_tokens:
      gpt-4o: 16384
      gpt-4o-mini: 16384
      gpt-4-turbo: 4096
      gpt-4: 8192
      gpt-3.5-turbo: 4096
      claude-3-opus: 4096
      claude-3-sonnet: 4096
      claude-3-haiku: 4096
      claude-3.5-sonnet: 8192
      claude-3.5-haiku: 8192
      claude-4-sonnet: 16384
      gemini-2.5-flash: 8192
      gemini-2.5-pro: 8192
      mistral-large: 8192
      mistral-small: 8192
      deepseek-chat: 8192
      deepseek-reasoner: 8192
      grok: 8192
      command-r: 4096
      command-r-plus: 4096
      llama: 8192
    verbosity_steering:
      enabled: false
      default_suffix: ''
      per_tenant_suffix: {}
    output_holdout:
      enabled: false
      fraction: 0.05
      sticky_key: workflow_id
  G12_reasoning:
    enabled: true
    default_effort: medium
    provider_params:
    - model_fragment: o1
      param_key: reasoning_effort
      is_effort_key: true
    - model_fragment: o3
      param_key: reasoning_effort
      is_effort_key: true
    - model_fragment: claude
      param_key: thinking
      budget_key: budget_tokens
      is_effort_key: false
    reasoning_suppression_prompts:
      low: '[BUDGET] Provide the final answer only - no reasoning steps, no chain-of-thought, no explanation.'
      medium: '[BUDGET] Keep reasoning minimal. One brief step max, then final answer.'
      high: null
    effort_map:
      low:
        openai: low
        anthropic_tokens: 1000
        gemini_thinking_budget: 512
      medium:
        openai: medium
        anthropic_tokens: 5000
        gemini_thinking_budget: 4096
      high:
        openai: high
        anthropic_tokens: 10000
        gemini_thinking_budget: 16000
  G13_batch:
    enabled: true
    max_batch_size: 50
    flush_interval_ms: 500
    default_model: gpt-4o-mini
    redis_stream_prefix: tok_opt:batch
    consumer_group: proxy-batch-consumers
    consumer_name: proxy-worker-1
    max_pending_ack_ms: 30000
    batch_topics: []
    provider_native: false
    completion_window: 24h
    poll_interval_seconds: 30
    toon_auto_detect: false
    toon_min_rows: 2
    toon_uniform_threshold: 1.0
    toon_allow_nested: false
    toon_require_net_savings: true
    toon_max_block_chars: 20000
  context_editing:
    enabled: false
    strategy: clear_tool_uses_20250919
    clear_tool_inputs: false
  G14_tool_output:
    enabled: true
    field_whitelist: {}
    spreadsheet_compression: true
  G15_server_compute:
    enabled: true
    headroom_mcp_server: true
    hooks: []
  G16_agent_arch:
    enabled: true
    max_system_prompt_tokens: 4096
    max_tools_per_agent: 10
  G17_loop:
    enabled: true
    max_iterations: 10
    starting_budget_tokens: 10000
    compact_output_below_tokens: 500
    confidence_stop_threshold: 0.95
    wall_clock_timeout_seconds: 300
  G18_observability:
    enabled: true
    langfuse_host: http://langfuse-svc
    prometheus_enabled: true
    capture_trace_content: true
    turn_efficiency_enabled: true
    tool_governance_enabled: true
    openllmetry_enabled: false
    openllmetry_endpoint: ''
    turn_efficiency_baseline_multiplier: 2.0
    tool_governance_days: 30
    jsonl_gcs_bucket: ''
    jsonl_gcs_prefix: token-usage-logs
    et_weights:
      input: 1.0
      cache_read: 0.1
      output: 4.0
    # B3 — discount-aware price book (reporting-only; refines the cost_actual estimate).
    # reasoning_rate_multiplier > 1.0 models a reasoning-token surcharge (1.0 = none).
    # batch_discount_multiplier applies ONLY to requests served via the native batch lane.
    reasoning_rate_multiplier: 1.0
    batch_discount_multiplier: 0.5
  G19_headroom:
    enabled: true
    request_side_enabled: true
    response_side_enabled: true
    min_length_to_compress: 50
    compression_strategies:
      json:
        remove_empty: true
        dedupe_keys: true
      code:
        strip_comments: true
        strip_whitespace: true
        compress_imports: true
      logs:
        dedupe_lines: true
        truncate_long_lines: 200
      text:
        dedupe_sentences: true
        max_sentence_len: 0
  G20_prompt_optimization:
    enabled: true
    optimizer: builtin
    model: gpt-4o-mini
    eval_sample_size: 100
    max_prompt_tokens: 4000
    quality_threshold: 0.95
    schedule: weekly
  G21_cache_alignment:
    enabled: true
    providers:
      openai:
        auto: true
        discount_pct: 50
        prompt_cache_key: true
        prompt_cache_key_len: 32
        cache_read_multiplier: 0.5
      anthropic:
        marker: false
        cache_type: ephemeral
        discount_pct: 90
        cache_read_multiplier: 0.1
      gemini:
        cache_read_multiplier: 0.25
      # New providers — cached-input discount for cost reporting (default 1.0 = none).
      deepseek:
        cache_read_multiplier: 0.1
      bedrock:
        cache_read_multiplier: 0.1
      azure:
        cache_read_multiplier: 0.5
      mistral:
        cache_read_multiplier: 1.0
      groq:
        cache_read_multiplier: 1.0
      cohere:
        cache_read_multiplier: 1.0
      xai:
        cache_read_multiplier: 1.0
  g22_deduplication:
    enabled: true
    dedup_threshold: 0.92
    embedding_model: BAAI/bge-small-en-v1.5
    use_embeddings: false
    tenant_thresholds: {}
  G23_streaming_compression:
    enabled: true
    min_repeat: 3
    ngram_size: 5
  G28_ccr:
    # Off by default: CCR replaces large content blocks with a [CCR:ref] token that
    # the model resolves via the headroom_retrieve MCP tool. That only works for a
    # client running an agent loop that calls the tool and re-sends the result; in a
    # plain pass-through chat completion the model can't resolve the reference and
    # answers from a gutted context. Enable only for cooperating agent clients.
    enabled: false
    min_tokens: 300                # replace string content blocks at/above this token count
    ttl_seconds: 86400
    expose_mcp_tools: true
    compress_system_prompt: false  # keep false — the system instruction must stay verbatim
                                   # (the model can't resolve a CCR ref for it in pass-through)
  G27_multimodal:
    enabled: true
    min_bytes: 4096
    quality: 75
  G24_adaptive_bypass:
    enabled: true
    rules_file: config/adaptive_bypass_rules.yaml
  G25_adaptive_reasoning:
    enabled: true
    effort_floor: low
    effort_ceiling: high
    extra_reasoning_prefixes: []
