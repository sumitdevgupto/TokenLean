params_dir: config/params
proxy:
  port: 4000
  api_key_header: Authorization
  log_level: INFO
  cors_origins:
  - '*'
  default_model: gpt-4o-mini
  fallback_request_model: gpt-4o-mini
  # Provider used when a model matches no providers[].model_prefixes (replaces the old
  # hardcoded "openai" fallback). Set to whichever provider your default_model belongs to.
  default_provider: openai
  allow_user_id_header_override: true
  allowed_user_id_headers:
  - '*@*.test'
services:
  llmlingua_url: http://llmlingua-svc:8080/compress
  qdrant_url: http://qdrant:6333
  tika_url: http://tika-svc:9998
  routellm_url: http://routellm-svc:8081
  langfuse_host: http://langfuse-svc:3000
  mem0_url: ''
  zep_url: ''
savings:
  chars_per_token: 4
  per_message_overhead: 4
  per_tool_overhead: 4
  # B2 / P11 — non-GPT models (Claude/Gemini/Mistral/…) use cl100k_base tiktoken locally
  # for a closer-than-char/4 ingress baseline (no provider API call). Approximate but better
  # than char/4; affects the savings-% estimate only — billed tokens come from provider usage.
  non_gpt_tiktoken_fallback: true
rate_limit:
  enabled: true
  default:
    requests_per_minute: 60
    requests_per_hour: 1000
  per_user:
    user-01:
      requests_per_minute: 2
      requests_per_hour: 120
  per_team:
    team-alpha:
      requests_per_minute: 20
      requests_per_hour: 1200
  # WS23: per-pricing-tier defaults + per-tenant overrides (most specific wins:
  # per_user > per_team > per_tenant > tiers > default). per_tenant entries are
  # normally applied by the operator through tenant_configs, not edited here.
  tiers: {}
  #  free:
  #    requests_per_minute: 30
  #    requests_per_hour: 600
  per_tenant: {}
  # Monthly request-quota gate from the billing rate card: 429 quota_exceeded past
  # included_requests x (1 + grace_pct/100). OFF by default — OSS/self-host never
  # enforces a quota; the managed SaaS enables it. included_requests of 0/absent
  # means unlimited. Exempt tenants are never gated.
  quota:
    enabled: false
    grace_pct: 10
    exempt_tenants: [admin, default]
  # Per-tenant monthly USD spend cap — the "denial-of-wallet" ceiling. 429
  # spend_cap_exceeded once the running t:<id>:spend:<YYYYMM> counter (summed real
  # cost_actual_usd) crosses the effective cap x (1 + grace_pct/100). OFF by default
  # — OSS/self-host never enforces a dollar ceiling; the managed SaaS enables it.
  # Effective cap = per-tenant override (limits.monthly_spend_cap_usd, set via the
  # portal into tenant_configs) > tier default (billing.rate_card.<tier>). Absent /
  # 0 cap means unlimited. Exempt tenants are never gated. Fail-open on Redis error.
  spend_cap:
    enabled: false
    grace_pct: 0
    exempt_tenants: [admin, default]
    warn_pct: 0                   # 0 = off. When >0, emit a one-shot `budget.threshold`
                                  # outbound webhook event the first time monthly spend
                                  # crosses this %% of the cap (e.g. 80). Delivery is a
                                  # commercial feature; the emit is a no-op without it.
  # Per-tenant FREE TRIAL gate: N days AND M served-2xx requests, whichever is hit
  # first. OFF by default — OSS/self-host never enforces trials; the managed SaaS
  # enables it. Per-tenant state lives in tenant_configs.config_overrides under
  # `trial:` {status: active|converted|cancelled, started_at (UTC ISO), days,
  # max_requests, generation} — written by the admin console at runtime and merged
  # into ctx.config per request (no redeploy). Expiry (days elapsed OR requests
  # exhausted) → HTTP 402 code=trial_expired until an operator converts or extends;
  # the 402 is not billed and does not consume trial allowance. Counting basis = the
  # billable unit (every served 2xx, incl. cache hits/bypasses). Trial requests are
  # flagged on usage_events and excluded from invoices. Warn %%s fire a one-shot
  # `trial.threshold` webhook per crossing (per trial generation); exhaustion fires
  # one `trial.expired` (delivery is commercial; no-op without a dispatcher).
  # Exempt tenants are never gated. Fail-open on Redis error (request dimension) and
  # on malformed trial state.
  trial:
    enabled: false
    exempt_tenants: [admin, default]
    warn_pcts: [80, 90]
# WS25: periodic data-retention purge (default OFF — self-host keeps everything).
# usage_days is clamped to a 400-day floor in code: usage_events is the billing
# source of record and must outlive every invoice period.
retention:
  enabled: false
  interval_hours: 24
  audit_days: 0                 # 0 = keep audit_events forever
  usage_days: 0                 # 0 = keep usage_events forever
  cache_l2_expired_cleanup: true
# App-level source-IP allowlist (CIDR) for the proxy request path. OFF by default —
# OSS/self-host is open; the managed enterprise deploy turns it on. Enforced in core
# _authenticate for the /v1/* routes (net/ip_allowlist.py). global_cidrs apply to ALL
# tenants (e.g. an office / VPN egress that must always work); per-tenant CIDRs are set
# from the adminconsole and stored in the tenant's key metadata. Empty global + empty
# per-tenant ⇒ the tenant is unrestricted. A request is allowed iff its source IP is in
# (global_cidrs ∪ tenant_cidrs).
ip_allowlist:
  enabled: false
  trust_x_forwarded_for: true   # first XFF hop is the client (Cloud Run / portal front the proxy)
  global_cidrs: []              # e.g. ["203.0.113.0/24", "198.51.100.7/32"]
providers:
- name: openai
  api_base: https://api.openai.com/v1
  # Optional per-provider resilience override (merges over the top-level `resilience:`
  # block). E.g. a flakier provider can trip its breaker sooner:
  #   resilience:
  #     failure_threshold: 3
  #     num_retries: 2
  models:
  - gpt-4o-mini
  - gpt-4o
  - o1
  - o3
  - gpt-4-5
  model_prefixes:
  - gpt
  - o1
  - o3
  - text-
  - davinci
  - babbage
  - curie
  - ada
  tiktoken_prefixes:
  - gpt
  - o1
  - o3
  - text-
  - davinci
  - babbage
  - curie
  - ada
- name: anthropic
  api_base: https://api.anthropic.com/v1
  models:
  - claude-haiku-4-5
  - claude-sonnet-4-5
  - claude-opus-4
  model_prefixes:
  - claude
# ── Additional first-class providers (each has a dedicated adapter) ─────────────────
# These resolve to their adapter class; the litellm namespace is baked into the adapter,
# so only model_prefixes are required. Set the matching LLM_KEY_<NAME> / llm-key-<name>.
# models[] lead with each provider's cheapest model (verify exact IDs against the provider).
- name: gemini
  models:
  - gemini-2.5-flash-lite      # cheapest Gemini
  - gemini-2.5-flash
  model_prefixes:
  - gemini
- name: mistral
  models:
  - ministral-3b-latest        # cheapest Mistral
  - mistral-small-latest
  model_prefixes:
  - mistral
  - mixtral
  - ministral
  - magistral
  - codestral
  - pixtral
- name: deepseek
  models:
  - deepseek-chat              # cheapest DeepSeek (deepseek-reasoner costs more)
  model_prefixes:
  - deepseek
- name: xai
  models:
  - grok-3-mini                # cheapest xAI
  model_prefixes:
  - grok
- name: cohere
  models:
  - command-r7b-12-2024        # cheapest Cohere
  - command-r
  model_prefixes:
  - command
  - cohere/
# Groq hosts many model families — route with an explicit "groq/" prefix to disambiguate.
- name: groq
  models:
  - groq/llama-3.1-8b-instant  # cheapest Groq
  model_prefixes:
  - groq/
# Azure shares OpenAI model names — route with an explicit "azure/<deployment>" and set
# api_base + api_version to your Azure resource. Key via LLM_KEY_AZURE.
- name: azure
  api_base: https://YOUR-RESOURCE.openai.azure.com
  api_version: '2024-10-21'
  # Azure model = your deployment name (azure/<deployment>); point it at a cheap deployment (e.g. gpt-4o-mini)
  model_prefixes:
  - azure/
# Bedrock uses AWS SigV4 (no bearer key) — creds from the environment / instance profile.
- name: bedrock
  aws_region: us-east-1
  models:
  - bedrock/amazon.nova-micro-v1:0   # cheapest Bedrock (Amazon Nova Micro)
  model_prefixes:
  - bedrock/
  - anthropic.
  - amazon.
  - meta.
  - mistral.
  - cohere.
  - us.anthropic.
# OpenRouter — aggregator exposing 200+ models behind one OpenAI-compatible API (config-only,
# generic adapter). Send models as "openrouter/<vendor>/<model>",
# e.g. openrouter/anthropic/claude-3.5-sonnet. Key via LLM_KEY_OPENROUTER.
- name: openrouter
  adapter: generic
  litellm_prefix: openrouter
  # Free models ($0). Verify the exact slug on each model's OpenRouter page (vendor/model:free).
  models:
  - openrouter/openai/gpt-oss-120b:free        # gpt-oss-120b (free)
  - openrouter/google/gemma-4-31b:free         # Gemma 4 31B (free)
  - openrouter/nvidia/nemotron-3-ultra:free    # Nemotron 3 Ultra (free)
  model_prefixes:
  - openrouter/
# OpenCode Zen — curated OpenAI-compatible gateway (config-only, generic adapter). Send models
# as "opencode/<model>" e.g. opencode/deepseek-v4-pro; the "opencode/" prefix is stripped before
# the upstream call. Key via LLM_KEY_OPENCODE.
- name: opencode
  adapter: generic
  openai_compatible: true
  api_base: https://opencode.ai/zen/v1
  route_prefix: opencode/
  # Lead model = Kimi K2.7 Code; the free models below are $0. Verify slugs on the OpenCode Zen dashboard.
  models:
  - opencode/kimi-k2.7-code        # Kimi K2.7 Code (default)
  - opencode/mimo-v2.5             # MiMo V2.5 (free)
  - opencode/qwen3.6-plus          # Qwen3.6 Plus (free)
  - opencode/minimax-m3            # MiniMax M3 (free)
  model_prefixes:
  - opencode/

# ── Provider resilience (#1 failover) ───────────────────────────────────────────────
# Circuit breaker + retry + per-tenant cooldown + failover on the live request paths.
# Signals are scoped so tenants can't affect each other: 429s (rate limits — a property
# of the tenant's key) set only THAT tenant's short cooldown; 5xx/timeouts (true provider
# health) feed the global per-provider breaker. Gates FAIL OPEN: the last viable target
# is always attempted, so a request is never rejected without a real provider attempt.
# `enabled: false` (or omitting this block) restores the pre-feature behaviour exactly:
# one attempt, provider error surfaced. NOTE this template opts in (retry-only, no
# fallbacks) — deployments keeping their existing config.yaml are unaffected.
# Per-provider overrides live under `providers[].resilience`. Per-tenant overrides are set
# through the tenant's config (portal / tenant_configs), which deep-merges a top-level
# `resilience:` block over this one. Breaker/cooldown state is per worker (in-process);
# hot-reloaded values apply immediately (no worker restart needed).
resilience:
  enabled: true
  num_retries: 1              # transient-error retries on the SAME model before failover
  failure_threshold: 5        # consecutive 5xx/timeout failures that trip a provider's breaker
  cooldown_seconds: 30        # breaker-open duration AND per-tenant 429-cooldown TTL
  retry_base_delay: 0.2       # exponential backoff base between retries (seconds)
  # Per-model lockout (finer than the provider breaker): quarantine ONE degraded /
  # deprecated model while the provider's OTHER models keep serving. Default off →
  # provider-breaker-only behaviour is unchanged. When on, a model that racks up
  # `model_failure_threshold` model-scoped 5xx/timeout failures is skipped on subsequent
  # requests for `model_lockout_seconds` (then one probe re-tests). The threshold is
  # deliberately lower than `failure_threshold` so a bad model is isolated before it can
  # open the whole-provider breaker; a fallback model's success then resets the breaker.
  model_lockout: false
  model_failure_threshold: 3
  # model_lockout_seconds: 30  # defaults to cooldown_seconds when unset
  # Failover chains: routed model → ordered list of fallback models, resolved lazily
  # (only when the primary actually fails — no per-request cost while healthy). A
  # fallback whose provider is gated or whose key the tenant lacks is skipped; a
  # fallback's own auth/config error moves on to the next. Empty = retry-only.
  fallbacks: {}
  # Example:
  #   gpt-4o-mini:
  #   - claude-haiku-4-5
  #   - gemini-2.5-flash-lite

pricing:
  gpt-4o-mini:
    input: 0.00015
    output: 0.0006
  gpt-4o:
    input: 0.005
    output: 0.015
  gpt-4-5:
    input: 0.075
    output: 0.15
  o1:
    input: 0.015
    output: 0.06
  o3:
    input: 0.01
    output: 0.04
  claude-haiku:
    input: 0.00025
    output: 0.00125
  claude-sonnet:
    input: 0.003
    output: 0.015
  claude-opus:
    input: 0.015
    output: 0.075
  # New providers (USD per 1k tokens — verify against current price sheets; reporting only,
  # billing is per-request). Keys are substring-matched against the routed model name.
  gemini-2.5-flash:
    input: 0.0003
    output: 0.0025
  gemini-2.5-pro:
    input: 0.00125
    output: 0.01
  mistral-large:
    input: 0.002
    output: 0.006
  mistral-small:
    input: 0.0002
    output: 0.0006
  deepseek-reasoner:
    input: 0.00055
    output: 0.00219
  deepseek:
    input: 0.00027
    output: 0.0011
  grok:
    input: 0.003
    output: 0.015
  command-r-plus:
    input: 0.0025
    output: 0.01
  command-r:
    input: 0.00015
    output: 0.0006
  llama:
    input: 0.00059
    output: 0.00079
  # Bedrock-hosted model fragments (substring-matched against the routed model name, e.g.
  # "anthropic.claude-3-5-sonnet", "amazon.nova-pro"). Azure is per-deployment — add a row
  # keyed by your deployment name; otherwise it falls back to `default` below.
  claude-3-5-sonnet:
    input: 0.003
    output: 0.015
  claude-3-5-haiku:
    input: 0.0008
    output: 0.004
  claude-3-haiku:
    input: 0.00025
    output: 0.00125
  claude-3-opus:
    input: 0.015
    output: 0.075
  nova-pro:
    input: 0.0008
    output: 0.0032
  nova-lite:
    input: 0.00006
    output: 0.00024
  nova-micro:
    input: 0.000035
    output: 0.00014
  # OpenCode Zen (per 1k tokens; keyed by full opencode/<model> so longest-match wins over the
  # generic provider rows; free models = 0). Source: opencode.ai/zen — adjust as prices change.
  opencode/deepseek-v4-pro:
    input: 0.00174
    output: 0.00348
  opencode/glm-5.2:
    input: 0.0014
    output: 0.0044
  opencode/kimi-k2.6:
    input: 0.00095
    output: 0.004
  opencode/kimi-k2.7-code:        # estimate — mirrors kimi-k2.6; verify on opencode.ai/zen
    input: 0.00095
    output: 0.004
  opencode/minimax-m2.7:
    input: 0.0003
