groups:
  G1_compression:
    enabled: true
    min_tokens_to_compress: 200
    compression_ratio_target: 0.5
    force_reserve_digit: true        # preserve digit tokens (dates/IDs/amounts) so compression can't corrupt a tool argument
    sidecar_url: http://llmlingua-svc:8080/compress
    min_chars_to_compress: 100
    reduction_threshold: 0.95
    compress_user_messages: false
    compress_system_prompt: false
    layered_composition_enabled: true
    layers:
      base: You are a helpful AI assistant.
      role: You specialize in {domain}.
      task: Your current task is to {task_description}.
      dynamic: 'Additional context: {context}'
    selective_context_enabled: false
    selective_context_max_tokens: 4000
    build_time_compression: true
    # Kompress-v2 fallback compression for logs/errors (applied when LLMLingua is not a fit)
    kompress_enabled: true
    kompress_model: microsoft/Kompress-v2-base
    kompress_max_new_tokens: 256
    # Deterministic regex prose fallback (zero-LLM, zero-latency; prose_compress).
    # Engages ONLY when neither LLMLingua nor Kompress reduced a message — so a
    # sidecar outage degrades to some savings instead of pass-through. Default off
    # (keeps the reproducible baseline byte-identical). Protects code/paths/idents.
    deterministic_fallback: false
  G2_template_registry:
    enabled: true
    # `budget` (singular) — global truncation policy applied when a prompt exceeds a template's
    # `budgets` (plural, per-template, below). truncate_enabled off = enforce budgets by reporting
    # only; on = actually shrink over-budget prompts (⚠ quality — drops content).
    budget:
      truncate_enabled: false
      truncate_strategy: tail_system
      min_keep_user_turns: 1
    deprecation_warn_days: 30
    template_history_ttl_days: 90
    max_history_per_version: 1000
    budgets:
      customer-support-classifier:
        version: '2.1'
        system_prompt_max: 400
        total_input_max: 800
        output_max: 150
        author: platform-team
        description: Classifies customer support tickets
  G3_doc_pipeline:
    enabled: true
    chunk_size_tokens: 400
    chunk_overlap_tokens: 50
    sparse_model: Qdrant/bm25
    dense_model: all-MiniLM-L6-v2
    rag_fallback:
      enabled: true
      collection: rag_docs
      top_k: 5
      similarity_threshold: 0.85
      strategies:
      - strict_hybrid
      - relaxed_hybrid
      - dense_only
      - sparse_only
    fine_tuning:
      enabled: true
      min_docs: 100
      stability_days: 30
      auto_trigger: false
    tika_sidecar:
      enabled: false
      url: http://tika-svc:9998
  G4_bypass:
    enabled: true
    database_first: true
    db_cache_ttl_seconds: 60         # how long DB-resolved bypass rules are cached before re-fetch
    default_confidence_threshold: 0.7
    keyword_weight: 0.4
    pattern_weight: 0.6
    rules:
    - name: order-status
      rule_id: bypass-002
      category: order
      confidence_threshold: 0.75
      keywords:
      - order status
      - track my order
      - where is my order
      patterns:
      - order\s*#?\s*\d+
      backend_url: ''
  G5_cache:
    enabled: true
    # tenant (default) | tenant+model | tenant+system | tenant+model+system
    #   tenant        — tenant-only isolation (keys byte-identical to pre-feature)
    #   +model        — also key on the REQUESTED model, so a multi-provider tenant
    #                   never gets one model's answer served for another
    #   +system       — also key on a fingerprint of the SYSTEM PROMPT. The L2
    #                   semantic key embeds user turns ONLY (a long system prompt
    #                   would dominate/truncate the embedding window), so without
    #                   this the key is blind to the system prompt: the same user
    #                   question under a RESTRICTIVE prompt can be served an answer
    #                   cached under a laxer one, bypassing the scope/persona/format
    #                   constraint. Enable if one tenant runs several personas, apps,
    #                   or agents through the same key. Costs some hit-rate.
    cache_scope: tenant
    l1_ttl_seconds: 3600
    # 384-dim local model, pre-baked into the proxy image and pinned to an immutable
    # HF revision in the Dockerfile (ARG L2_EMBEDDING_REVISION, currently
    # 5c38ec7c405ec4b44b94cc5a9bb96e735b38267a). If you change this model name, bump
    # that Dockerfile ARG to the matching revision and rebuild — the two must stay in
    # sync, and a dimension change also requires migrating the cache_l2 pgvector table.
    l2_embedding_model: BAAI/bge-small-en-v1.5
    l2_similarity_threshold: 0.9
    l2_max_embed_chars: 2000
    semantic_skip_multiturn: true
    l2_ttl_seconds: 86400
    step_cache_enabled: true
    step_cache_ttl_seconds: 86400
    l3_enabled: true
    l3_similarity_threshold: 0.85
    auto_ttl_enabled: true
    auto_ttl_min_multiplier: 0.25
    auto_ttl_max_multiplier: 2.0
  G6_routing:
    enabled: true
    classifier: cascade
    cascade_execution: false
    # Routing STRATEGY — picks WHICH model of a chosen tier's list to use (the classifier
    # picks the tier; this picks within it). Default `priority` = the tier's first model,
    # byte-identical to the historical behaviour (the 54.1%% savings baseline is unchanged
    # until a tenant opts into a non-default strategy). Options:
    #   priority       — always the first model of the tier (default)
    #   round_robin    — rotate across the tier's models (per worker)
    #   weighted       — deterministic split by `strategy_weights` (model → weight)
    #   least_latency  — the tier model with the lowest observed served-latency EWMA
    #   canary         — `canary_pct`%% of traffic to the SECOND model, rest to the first
    strategy: priority
    strategy_weights: {}       # e.g. {gpt-4o-mini: 9, gpt-4o: 1} for the `weighted` strategy
    canary_pct: 0              # % to the canary (2nd model) when strategy: canary
    least_latency_alpha: 0.3   # EWMA smoothing for `least_latency` (0-1; higher = reacts
                               # faster to recent calls, lower = smoother/slower to react)
    # When a routed tier model's provider has no usable credential (e.g. an OpenAI-free
    # deployment left the default gpt-4o tiers): `fallback` (default) serves the caller's
    # own requested model — cost-routing simply no-ops; `error` returns a clean 503.
    on_unreachable_tier: fallback
    tiers:
      simple:
      - gpt-4o-mini
      medium:
      - gpt-4o
      complex:
      - gpt-4-5
    judge_model: ${G06_JUDGE_MODEL:-}
    judge_timeout_ms: 2000
    cascade_confidence_threshold: 0.7
    # Max cost DELTA (input + expected output, vs the previous tier) a single cascade
    # escalation may add. Small requests jumping into a pricey tier are blocked here.
    max_escalation_cost_usd: 0.01
    # Over-escalation guards. cap_to_classified_tier (execution cascade only): the
    # cascade may climb at most to the tier the request itself classifies as, so a
    # plain "medium" query is never pushed to the expensive complex tier (an
    # x_complexity override bypasses the cascade entirely). allow_escalation_above_
    # requested: when false (default), G06 never routes to a model costlier than the one
    # the caller requested — enforced BOTH in the execution cascade AND on the label
    # paths (heuristic / llm_judge / routellm), where a mis-classified "medium"/"complex"
    # tier that outprices the requested model reverts to the requested model. Routing
    # only ever saves cost, never adds it. Explicit x_complexity user overrides are exempt.
    cascade_cap_to_classified_tier: true
    allow_escalation_above_requested: false
    # No-judge response-adequacy scores (used when judge_model is empty), compared
    # against cascade_confidence_threshold to decide whether to escalate. Scores the
    # tier's actual answer: ok = clean stop, truncated = hit max_tokens, refusal =
    # content-filter / "I can't help" opening, empty = blank content.
    response_confidence:
      ok: 0.85
      truncated: 0.30
      refusal: 0.40
      empty: 0.0
    # Output cap injected on the tier-1 probe ONLY when the caller sent no max_tokens
    # (a caller-supplied max_tokens always wins). 0 = never inject; the provider's
    # default applies. Bounds the cost of the cheap probe call.
    cascade_tier1_max_tokens: 512
    # If the cascade settles on the tier-1 probe as the FINAL answer but that answer
    # was truncated by the injected cap above (finish_reason == "length"), retry the
    # tier-1 model once without the cap before serving. A self-inflicted truncation
    # must never be the customer's answer. No-op when the caller set max_tokens.
    cascade_retry_uncapped_on_truncation: true
    # Expected output tokens used ONLY for cost estimates (escalation guards +
