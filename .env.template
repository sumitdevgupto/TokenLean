# TokenLean — Token Optimisation Framework — Local Docker Environment Template
# =============================================================================
# Copy this file to .env and fill in your real values.
# .env is gitignored — NEVER commit it.
#
# Quick start:
#   cp .env.template .env
#   # Edit .env and replace "replace-with-real-key" with your real keys
#   ./scripts/local/deploy-local.sh --with-grafana
# =============================================================================

# ═══════════════════════════════════════════════════════════════════════════════
# MANDATORY — Must set real values for local deployment to work
# ═══════════════════════════════════════════════════════════════════════════════

# ─── OpenAI API Key (REQUIRED) ────────────────────────────────────────────────
# Used by: RouteLLM (G06) for embeddings, and proxy for OpenAI provider calls
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-replace-with-real-key

# ─── Proxy LLM Key (REQUIRED) ─────────────────────────────────────────────────
# Used by: Proxy for LLM provider authentication
# Can be same as OPENAI_API_KEY above
LLM_KEY_OPENAI=sk-replace-with-real-key

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Safe to leave as defaults for local development
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Docker Compose ───────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=token-opt

# ─── GCP (referenced by some services; safe to leave for pure local dev) ──────
GCP_PROJECT_ID=token-optimisation
GCP_REGION=asia-south1

# ─── Config ───────────────────────────────────────────────────────────────────
# Leave blank to use local config/config.yaml (recommended for local dev)
CONFIG_GCS_BUCKET=
CONFIG_GCS_BLOB=config/config.yaml
CONFIG_LOCAL_PATH=/app/config/config.yaml

# ─── Database (PostgreSQL + pgvector) ─────────────────────────────────────────
# REQUIRED — set a strong password; used by proxy, langfuse, and openmeter services
DB_PASSWORD=
DATABASE_URL=postgresql://token_opt:${DB_PASSWORD}@postgres:5432/token_opt
# REQUIRED if using the 'billing' profile (openmeter); must use same postgres host
OPENMETER_DB_URL=postgresql://token_opt:${DB_PASSWORD}@postgres:5432/token_opt

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local Docker Redis (default) — comment out if using external (e.g. Upstash)
REDIS_URL=redis://redis:6379/0
# External Redis example (uncomment if needed):
# REDIS_URL=rediss://default:xxx@your-redis.upstash.io:6379

# ─── Qdrant (vector DB for G07 RAG, G10 Memory) ───────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_docs

# ─── LLMLingua Sidecar (G01 Compression) ──────────────────────────────────────
LLMLINGUA_SIDECAR_URL=http://llmlingua:8080

# ─── RouteLLM Sidecar (G06 Routing) ─────────────────────────────────────────
ROUTELLM_STRONG_MODEL=gpt-4o
ROUTELLM_WEAK_MODEL=gpt-4o-mini
ROUTELLM_URL=http://routellm:8080
# G06 cascade complexity judge model — referenced by config.yaml groups.G6_routing.judge_model.
# Empty = built-in word-count heuristic; set a model (e.g. gpt-4o-mini) for LLM-scored confidence.
G06_JUDGE_MODEL=

# ─── Tika Sidecar (G03 Document Extraction) ─────────────────────────────────
TIKA_URL=http://tika:9998

# ─── Langfuse (G18 Observability) ───────────────────────────────────────────
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local
# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
NEXTAUTH_SECRET=
# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SALT=

# ─── Grafana (Optional — use --with-grafana flag) ─────────────────────────────
# REQUIRED if using the 'observability' profile
GRAFANA_PASSWORD=

# ─── Optional LLM Provider Keys ───────────────────────────────────────────────
# Only needed if testing non-OpenAI providers locally. Each maps to the provider name
# (LLM_KEY_<NAME> → providers[].name) used by the proxy's adapters.
LLM_KEY_ANTHROPIC=sk-ant-replace-with-real-key
LLM_KEY_GOOGLE=AI-replace-with-real-key
LLM_KEY_GEMINI=AI-replace-with-real-key
LLM_KEY_MISTRAL=replace-with-real-key
LLM_KEY_COHERE=replace-with-real-key
LLM_KEY_DEEPSEEK=sk-replace-with-real-key
LLM_KEY_XAI=xai-replace-with-real-key
LLM_KEY_GROQ=gsk-replace-with-real-key
# OpenRouter — aggregator (OpenAI-compatible); models as openrouter/<vendor>/<model>
LLM_KEY_OPENROUTER=sk-or-replace-with-real-key
# OpenCode Zen — curated OpenAI-compatible gateway; models as opencode/<model>
LLM_KEY_OPENCODE=replace-with-real-key
# Azure OpenAI — key + endpoint/version come from the azure provider entry in config.yaml
LLM_KEY_AZURE=replace-with-real-key
# AWS Bedrock uses SigV4 credentials (no single key). Set standard AWS env vars instead:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=us-east-1

# ─── Proxy Key Management ─────────────────────────────────────────────────────
PROXY_KEYS_SECRET_NAME=token-proxy-api-keys
KEY_CACHE_TTL_SECONDS=300

# ─── Savings calculator constants (rarely need changing) ──────────────────────
# chars-per-token fallback for non-tiktoken models (playbook default: 4)
# CHARS_PER_TOKEN=4
# PER_MESSAGE_OVERHEAD_TOKENS=4
# PER_TOOL_OVERHEAD_TOKENS=4

# ─── Skills / memory config ───────────────────────────────────────────────────
# SKILLS_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# SKILLS_SIMILARITY_THRESHOLD=0.70
# MEMORY_QUERY_MAX_CHARS=400

# ─── Tool loading / G08 ───────────────────────────────────────────────────────
# TOOL_REGISTRY_CACHE_TTL_SECONDS=300
# MCP_MANIFEST_CACHE_TTL_SECONDS=300
# MCP_HTTP_TIMEOUT_SECONDS=10.0
# TOOL_USAGE_TTL_DAYS=90
# TOOL_PRUNING_INTERVAL_HOURS=24
# TOOL_INACTIVITY_THRESHOLD_DAYS=30

# ─── Template registry / G02 ─────────────────────────────────────────────────
# TEMPLATE_DEPRECATION_WARN_DAYS=30
# TEMPLATE_HISTORY_TTL_DAYS=90
# TEMPLATE_MAX_HISTORY_PER_VERSION=1000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Container memory limits ─────────────────────────────────────────────────
# Increase for large model workloads; decrease for constrained dev machines
LLMLINGUA_MEM=2g
PROXY_MEM=4g
ROUTELLM_MEM=2g

# ─── Tika document extraction limits ──────────────────────────────────────────
TIKA_MAX_FILE_SIZE=100000000
TIKA_TIMEOUT_MS=30000

# ─── G13 Kafka Backend (default is Redis Streams) ───────────────────────────────
# Uncomment to use Kafka instead of Redis for batch processing
# G13_USE_KAFKA=false
# KAFKA_BROKERS=localhost:9092
# KAFKA_BATCH_TOPIC=token-opt-batch-requests

# ─── Override Default Ports ───────────────────────────────────────────────────
# Only change if you have port conflicts
# PROXY_PORT=4000
# LLMLINGUA_PORT=8080
# ROUTELLM_PORT=8081
# QDRANT_PORT=6333
# TIKA_PORT=9998
# LANGFUSE_PORT=3100
# GRAFANA_PORT=3000
