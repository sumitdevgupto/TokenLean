# Token Optimisation Framework — GCP Deployment Environment
# Copy to .env.gcp and fill in your values. .env.gcp is gitignored — NEVER commit it.
#
# Usage:
#   source .env.gcp && ./scripts/gcp/gcp-deploy.sh
#   source .env.gcp && ./scripts/gcp/start-gcp.sh
#   source .env.gcp && ./scripts/gcp/stop-gcp.sh

# ─── GCP Project ──────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1

# ─── Config GCS Bucket (auto-created by Terraform if left blank) ──────────────
CONFIG_GCS_BUCKET=
CONFIG_GCS_BLOB=config/config.yaml

# ─── Terraform State (auto-created by gcp-deploy.sh if left blank) ────────────
TF_STATE_BUCKET=${GCP_PROJECT_ID}-tf-state

# ─── LLM Keys (loaded from config/keys.yaml by gcp-deploy.sh — do NOT put here) ──
# Provider API keys are stored in GCP Secret Manager only.

# ─── Optional: Override default service names ─────────────────────────────────
# SQL_INSTANCE=token-opt-pg
# REDIS_INSTANCE=token-opt-redis

# ─── Optional: Routing (G06) ──────────────────────────────────────────────────
# Cascade complexity judge model — referenced by config.yaml groups.G6_routing.judge_model.
# Empty/unset = built-in word-count heuristic. Set (e.g. gpt-4o-mini) for LLM-scored confidence.
# G06_JUDGE_MODEL=
