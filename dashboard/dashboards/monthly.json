{
  "title": "Token Savings - Monthly",
  "uid": "token-opt-monthly",
  "tags": [
    "token-optimisation"
  ],
  "schemaVersion": 38,
  "refresh": "30m",
  "time": {
    "from": "now-12M",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Calls (This Month)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) FROM traces WHERE ('${tenant}' = '.*' OR metadata->>'tenant_id' = '${tenant}') AND created_at >= date_trunc('month', NOW())",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Tokens Saved (This Month)",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT SUM((metadata->>'total_abs_saving')::int) FROM traces WHERE ('${tenant}' = '.*' OR metadata->>'tenant_id' = '${tenant}') AND created_at >= date_trunc('month', NOW())",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cost Saved (This Month, USD)",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(SUM((metadata->>'cost_saving_usd')::float)::numeric,2) FROM traces WHERE created_at >= date_trunc('month', NOW())",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 6
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Saving % (This Month)",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG((metadata->>'total_pct_saving')::float)::numeric,1) FROM traces WHERE created_at >= date_trunc('month', NOW())",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Unique Users (This Month)",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT metadata->>'user_id') FROM traces WHERE created_at >= date_trunc('month', NOW())",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Cache Hit Rate (This Month)",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN (metadata->>'cache_hit')::boolean THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 1) FROM traces WHERE created_at >= date_trunc('month', NOW())",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Monthly Tokens Saved (rolling 12 months)",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('month', created_at) AS time, SUM((metadata->>'total_abs_saving')::int) AS tokens_saved FROM traces WHERE created_at >= NOW() - INTERVAL '12 months' GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Monthly Cost Saved (rolling 12 months, USD)",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('month', created_at) AS time, ROUND(SUM((metadata->>'cost_saving_usd')::float)::numeric,2) AS cost_saved FROM traces WHERE created_at >= NOW() - INTERVAL '12 months' GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "lineWidth": 2
          },
          "decimals": 6
        }
      }
    },
    {
      "id": 9,
      "type": "barchart",
      "title": "Month-over-Month Call Volume",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT to_char(date_trunc('month', created_at), 'Mon YYYY') AS month, COUNT(*) AS calls FROM traces WHERE created_at >= NOW() - INTERVAL '12 months' GROUP BY date_trunc('month', created_at), 1 ORDER BY date_trunc('month', created_at)",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 10,
      "type": "piechart",
      "title": "G-Group Contribution (This Month)",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT key AS g_group, SUM((value->>'abs_saving')::int) AS tokens_saved FROM traces, jsonb_each(metadata->'step_savings') WHERE created_at >= date_trunc('month', NOW()) GROUP BY 1 ORDER BY tokens_saved DESC LIMIT 10",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": true,
          "calc": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "pieType": "pie",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "tooltip": {
          "mode": "single",
          "sort": "desc"
        },
        "displayLabels": [
          "name",
          "percent"
        ]
      }
    },
    {
      "id": 11,
      "type": "table",
      "title": "Monthly Summary by User",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT to_char(date_trunc('month', created_at), 'YYYY-MM') AS month, metadata->>'user_id' AS user_id, COUNT(*) AS calls, SUM((metadata->>'total_abs_saving')::int) AS tokens_saved, ROUND(AVG((metadata->>'total_pct_saving')::float)::numeric,1) AS avg_pct_saving, ROUND(SUM((metadata->>'cost_saving_usd')::float)::numeric,4) AS cost_saved_usd, COUNT(DISTINCT metadata->>'routed_model') AS models_used FROM traces WHERE created_at >= NOW() - INTERVAL '12 months' AND ('${user_id}' = 'All' OR metadata->>'user_id' = '${user_id}') GROUP BY 1,2 ORDER BY 1 DESC, tokens_saved DESC",
          "format": "table"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "user_id",
        "type": "query",
        "label": "User",
        "datasource": {
          "uid": "langfuse-postgres"
        },
        "query": "SELECT DISTINCT metadata->>'user_id' FROM traces WHERE created_at >= NOW() - INTERVAL '12 months' ORDER BY 1",
        "current": {
          "selected": true,
          "text": "All",
          "value": "All"
        },
        "includeAll": true,
        "allValue": "All",
        "multi": false,
        "refresh": 2
      },
      {
        "name": "tenant",
        "type": "query",
        "label": "Tenant",
        "datasource": {
          "uid": "prometheus"
        },
        "definition": "label_values(token_opt_requests_total, tenant_id)",
        "query": "label_values(token_opt_requests_total, tenant_id)",
        "includeAll": true,
        "multi": false,
        "allValue": ".*",
        "current": {
          "value": "$__all",
          "text": "All"
        },
        "refresh": 2
      }
    ]
  }
}