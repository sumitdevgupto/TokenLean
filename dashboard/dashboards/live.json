{
  "title": "Token Optimisation - Live Calls",
  "uid": "token-opt-live",
  "tags": [
    "token-optimisation",
    "live"
  ],
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(token_opt_requests_total{tenant_id=~\"$tenant\"}[$__range]))",
          "instant": true,
          "legendFormat": "requests"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requests / sec",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(token_opt_requests_total{tenant_id=~\"$tenant\"}[1m]))",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cache Hit Rate",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(sum(rate(token_opt_cache_hits_total{tenant_id=~\"$tenant\"}[5m])) or vector(0)) / (sum(rate(token_opt_requests_total{tenant_id=~\"$tenant\"}[5m])) or vector(1)) * 100",
          "legendFormat": "hit rate %",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "green",
                "value": 50
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Saving %",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "increase(token_opt_savings_pct_sum[$__range]) / increase(token_opt_savings_pct_count[$__range])",
          "format": "time_series",
          "legendFormat": "Avg Saving %",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active Teams",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(count by (team)(increase(token_opt_requests_total[$__range]) > 0))",
          "instant": true,
          "legendFormat": "active teams"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Cost (USD)",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(token_opt_cost_usd_total[$__range]))",
          "instant": true,
          "legendFormat": "cost USD"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Requests / min - All Users",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(token_opt_requests_total[1m])) * 60",
          "legendFormat": "all users"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Requests / min - by Team",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (team) (rate(token_opt_requests_total[1m])) * 60",
          "legendFormat": "{{team}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Token Savings % (rolling)",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('minute', created_at) AS time, ROUND(AVG((metadata->>'total_pct_saving')::float)::numeric,1) AS avg_saving_pct FROM traces WHERE ('${tenant}' = '.*' OR metadata->>'tenant_id' = '${tenant}') AND $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Per-Group Token Savings (live, by G0X)",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (group) (rate(token_opt_group_tokens_saved_total[5m])) * 300",
          "legendFormat": "{{group}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 10,
      "type": "barchart",
      "title": "Active Users (by calls)",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT metadata->>'user_id' AS user_id, COUNT(*) AS calls FROM traces WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY calls DESC LIMIT 20",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 11,
      "type": "table",
      "title": "Last 50 Calls",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT created_at AS \"Time\", id AS \"Request ID\", metadata->>'user_id' AS \"User\", metadata->>'routed_model' AS \"Model\", (metadata->>'baseline_tokens')::int AS \"Baseline Tokens\", (metadata->>'final_tokens_sent')::int AS \"Tokens Sent\", ROUND((metadata->>'total_pct_saving')::float::numeric,1) AS \"Saving %\", ROUND((metadata->>'cost_saving_usd')::float::numeric,6) AS \"Cost Saved ($)\", CASE WHEN (metadata->>'cache_hit')::boolean THEN metadata->>'cache_level' ELSE 'miss' END AS \"Cache\", CASE WHEN (metadata->>'bypassed')::boolean THEN 'yes' ELSE 'no' END AS \"Bypassed\" FROM traces ORDER BY created_at DESC LIMIT 50",
          "format": "table"
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "Time",
            "desc": true
          }
        ]
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "user_id",
        "type": "query",
        "label": "User",
        "datasource": {
          "uid": "langfuse-postgres"
        },
        "query": "SELECT DISTINCT metadata->>'user_id' FROM traces WHERE created_at >= NOW() - INTERVAL '24 hours' ORDER BY 1",
        "current": {
          "value": "$__all",
          "text": "All"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2
      },
      {
        "name": "tenant",
        "type": "query",
        "label": "Tenant",
        "datasource": {
          "uid": "prometheus"
        },
        "definition": "label_values(token_opt_requests_total, tenant_id)",
        "query": "label_values(token_opt_requests_total, tenant_id)",
        "includeAll": true,
        "multi": false,
        "allValue": ".*",
        "current": {
          "value": "$__all",
          "text": "All"
        },
        "refresh": 2
      }
    ]
  }
}