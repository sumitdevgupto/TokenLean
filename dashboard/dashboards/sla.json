      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, tenant_id) (rate(token_opt_request_duration_ms_bucket{tenant_id=~\"$tenant\"}[5m])))",
          "legendFormat": "{{tenant_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Error Rate Trend",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (tenant_id) (rate(token_opt_http_requests_total{status=~\"5..\",tenant_id=~\"$tenant\"}[5m])) / sum by (tenant_id) (rate(token_opt_http_requests_total{tenant_id=~\"$tenant\"}[5m])) * 100",
          "legendFormat": "{{tenant_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Uptime %",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 7,
        "h": 3
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(1 - ((sum(increase(token_opt_http_requests_total{status=~\"5..\",tenant_id=~\"$tenant\"}[$__range])) or vector(0)) / sum(increase(token_opt_http_requests_total{tenant_id=~\"$tenant\"}[$__range])))) * 100",
          "legendFormat": "uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "text": {
          "titleSize": 17,
          "valueSize": 30
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Tokens Saved vs SLA Target",
      "gridPos": {
        "x": 8,
        "y": 16,
        "w": 16,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "app-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('hour', timestamp) AS time, ROUND(AVG(CASE WHEN baseline_tokens > 0 THEN 100.0 * tokens_saved / baseline_tokens ELSE 0 END)::numeric, 1) AS avg_saving_pct FROM usage_events WHERE timestamp >= NOW() - INTERVAL '24 hours' AND ('${tenant}' = '.*' OR tenant_id = '${tenant}') GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "datasource": {
            "type": "postgres",
            "uid": "app-postgres"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Proxy time by stage \u2014 p95 (ms)",
      "description": "Per-pipeline-stage p95 latency (G-group granularity) \u2014 shows which stage drives the 'Proxy only' latency above. Note: provider calls made inside a stage (G06 cascade/judge, G10 summary) appear here as stage time but are counted as LLM time in the 'Proxy only' cards, not proxy overhead.",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 24,
        "h": 9
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(token_opt_stage_duration_ms_bucket{tenant_id=~\"$tenant\"}[5m])))",
          "legendFormat": "{{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 0
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "max",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 16,
      "type": "row",
      "title": "Provider Resilience (#1 failover)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 34,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
