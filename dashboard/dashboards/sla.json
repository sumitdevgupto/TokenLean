      "gridPos": {
        "x": 5,
        "y": 35,
        "w": 5,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(token_opt_failover_total{tenant_id=~\"$tenant\"}[5m])) or vector(0)",
          "legendFormat": "failovers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center"
      }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Circuit Breaker State by Provider (0=closed,1=half-open,2=open)",
      "gridPos": {
        "x": 10,
        "y": 35,
        "w": 14,
        "h": 8
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "token_opt_circuit_breaker_state",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 2,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Failover Rate by Serving Provider",
      "gridPos": {
        "x": 0,
        "y": 39,
        "w": 10,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (to_provider) (rate(token_opt_failover_total{tenant_id=~\"$tenant\"}[5m]))",
          "legendFormat": "\u2192 {{to_provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "label": "Tenant",
        "datasource": {
          "uid": "prometheus"
        },
        "definition": "label_values(token_opt_requests_total, tenant_id)",
        "query": "label_values(token_opt_requests_total, tenant_id)",
        "includeAll": true,
        "multi": false,
        "allValue": ".*",
        "current": {
          "value": "$__all",
          "text": "All"
        },
        "refresh": 2
      }
    ]
  }
