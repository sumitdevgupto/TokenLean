{
  "title": "Token Optimisation - SLA Monitoring",
  "uid": "token-opt-sla",
  "tags": [
    "token-optimisation",
    "sla"
  ],
  "schemaVersion": 38,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "links": [
    {
      "title": "Latency Breakup (per-step)",
      "type": "dashboards",
      "tags": [
        "latency"
      ],
      "asDropdown": false,
      "icon": "bolt",
      "includeVars": true,
      "keepTime": true
    }
  ],
  "panels": [
    {
      "id": 9,
      "type": "row",
      "title": "Overall (end-to-end)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "p99 Latency (ms)",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 5,
        "h": 3
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(token_opt_request_duration_ms_bucket{tenant_id=~\"$tenant\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 10000
              },
              {
                "color": "red",
                "value": 30000
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "text": {
          "titleSize": 17,
          "valueSize": 30
        }
      }
    },
