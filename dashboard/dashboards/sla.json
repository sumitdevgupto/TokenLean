    {
      "id": 14,
      "type": "stat",
      "title": "Error Rate (%)",
      "description": "Proxy-originated 5xx only \u2014 excludes 502s, which are provider-side LLM failures.",
      "gridPos": {
        "x": 15,
        "y": 5,
        "w": 5,
        "h": 3
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(sum(rate(token_opt_http_requests_total{status=~\"5..\",status!=\"502\",tenant_id=~\"$tenant\"}[5m])) or vector(0)) / sum(rate(token_opt_http_requests_total{tenant_id=~\"$tenant\"}[5m])) * 100",
          "legendFormat": "error_rate"
        }
      ],
      "fieldConfig": {
