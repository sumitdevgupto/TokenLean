      "id": 17,
      "type": "stat",
      "title": "Open Breakers",
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 5,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(token_opt_circuit_breaker_state == 2) or vector(0)",
          "legendFormat": "open"
