    {
      "id": 4,
      "type": "stat",
      "title": "Error Rate (%)",
      "gridPos": {
        "x": 15,
        "y": 1,
        "w": 5,
        "h": 3
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(sum(rate(token_opt_http_requests_total{status=~\"5..\",tenant_id=~\"$tenant\"}[5m])) or vector(0)) / sum(rate(token_opt_http_requests_total{tenant_id=~\"$tenant\"}[5m])) * 100",
          "legendFormat": "error_rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
