    {
      "id": 11,
      "type": "stat",
      "title": "p99 Latency (ms)",
      "description": "Proxy-induced latency only: end-to-end duration minus provider LLM call time. Cache hits and bypasses never reach the provider, so their full duration counts as proxy time.",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 5,
        "h": 3
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(token_opt_proxy_overhead_ms_bucket{tenant_id=~\"$tenant\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
