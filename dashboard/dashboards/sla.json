{
  "title": "Token Optimisation - SLA Monitoring",
  "uid": "token-opt-sla",
  "tags": [
    "token-optimisation",
    "sla"
  ],
  "schemaVersion": 38,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 9,
      "type": "row",
      "title": "Overall (end-to-end)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "p99 Latency (ms)",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(token_opt_request_duration_ms_bucket{tenant_id=~\"$tenant\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 300
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "p95 Latency (ms)",
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(token_opt_request_duration_ms_bucket{tenant_id=~\"$tenant\"}[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "p50 Latency (ms)",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(token_opt_request_duration_ms_bucket{tenant_id=~\"$tenant\"}[5m])))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error Rate (%)",
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(sum(rate(token_opt_http_requests_total{status=~\"5..\",tenant_id=~\"$tenant\"}[5m])) or vector(0)) / sum(rate(token_opt_http_requests_total{tenant_id=~\"$tenant\"}[5m])) * 100",
          "legendFormat": "error_rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1.0
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Proxy only",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 11,
      "type": "stat",
      "title": "p99 Latency (ms)",
      "description": "Proxy-induced latency only: end-to-end duration minus provider LLM call time. Cache hits and bypasses never reach the provider, so their full duration counts as proxy time.",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(token_opt_proxy_overhead_ms_bucket{tenant_id=~\"$tenant\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 300
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "p95 Latency (ms)",
      "description": "Proxy-induced latency only: end-to-end duration minus provider LLM call time.",
      "gridPos": {
        "x": 6,
        "y": 6,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(token_opt_proxy_overhead_ms_bucket{tenant_id=~\"$tenant\"}[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "p50 Latency (ms)",
      "description": "Proxy-induced latency only: end-to-end duration minus provider LLM call time.",
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(token_opt_proxy_overhead_ms_bucket{tenant_id=~\"$tenant\"}[5m])))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Error Rate (%)",
      "description": "Proxy-originated 5xx only — excludes 502s, which are provider-side LLM failures.",
      "gridPos": {
        "x": 18,
        "y": 6,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(sum(rate(token_opt_http_requests_total{status=~\"5..\",status!=\"502\",tenant_id=~\"$tenant\"}[5m])) or vector(0)) / sum(rate(token_opt_http_requests_total{tenant_id=~\"$tenant\"}[5m])) * 100",
          "legendFormat": "error_rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1.0
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "p99 Latency Trend",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, tenant_id) (rate(token_opt_request_duration_ms_bucket{tenant_id=~\"$tenant\"}[5m])))",
          "legendFormat": "{{tenant_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Error Rate Trend",
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (tenant_id) (rate(token_opt_http_requests_total{status=~\"5..\",tenant_id=~\"$tenant\"}[5m])) / sum by (tenant_id) (rate(token_opt_http_requests_total{tenant_id=~\"$tenant\"}[5m])) * 100",
          "legendFormat": "{{tenant_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Uptime %",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(1 - ((sum(increase(token_opt_http_requests_total{status=~\"5..\",tenant_id=~\"$tenant\"}[$__range])) or vector(0)) / sum(increase(token_opt_http_requests_total{tenant_id=~\"$tenant\"}[$__range])))) * 100",
          "legendFormat": "uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Tokens Saved vs SLA Target",
      "gridPos": {
        "x": 8,
        "y": 18,
        "w": 16,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "app-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('hour', timestamp) AS time, ROUND(AVG(CASE WHEN baseline_tokens > 0 THEN 100.0 * tokens_saved / baseline_tokens ELSE 0 END)::numeric, 1) AS avg_saving_pct FROM usage_events WHERE timestamp >= NOW() - INTERVAL '24 hours' AND ('${tenant}' = '.*' OR tenant_id = '${tenant}') GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "datasource": {
            "type": "postgres",
            "uid": "app-postgres"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "label": "Tenant",
        "datasource": {
          "uid": "prometheus"
        },
        "definition": "label_values(token_opt_requests_total, tenant_id)",
        "query": "label_values(token_opt_requests_total, tenant_id)",
        "includeAll": true,
        "multi": false,
        "allValue": ".*",
        "current": {
          "value": "$__all",
          "text": "All"
        },
        "refresh": 2
      }
    ]
  }
}
