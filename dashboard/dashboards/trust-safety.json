{
  "title": "Token Optimisation - Trust & Safety",
  "uid": "token-opt-trust-safety",
  "tags": [
    "token-optimisation",
    "trust-safety",
    "security"
  ],
  "schemaVersion": 38,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "label": "Tenant",
        "datasource": {
          "uid": "prometheus"
        },
        "definition": "label_values(token_opt_requests_total, tenant_id)",
        "query": "label_values(token_opt_requests_total, tenant_id)",
        "includeAll": true,
        "multi": false,
        "allValue": ".*",
        "current": {
          "value": "$__all",
          "text": "All"
        },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "PII Redaction (G29)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "PII spans redacted",
      "description": "Total PII spans detected & redacted over the selected time range.",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 3 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(token_opt_pii_redactions_total{tenant_id=~\"$tenant\"}[$__range])) or vector(0)",
          "legendFormat": "spans"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "text": { "valueSize": 36 }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Requests scanned",
      "description": "Total requests G29 inspected for PII over the selected time range.",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 3 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(token_opt_requests_total{tenant_id=~\"$tenant\"}[$__range])) or vector(0)",
          "legendFormat": "requests"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "text": { "valueSize": 28 }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "text" }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "PII spans by entity type",
      "gridPos": { "x": 6, "y": 1, "w": 10, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (entity_type) (increase(token_opt_pii_redactions_total{tenant_id=~\"$tenant\"}[$__rate_interval]))",
          "legendFormat": "{{entity_type}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": { "mode": "normal", "group": "A" }
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "PII spans by policy action",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (action) (increase(token_opt_pii_redactions_total{tenant_id=~\"$tenant\"}[$__rate_interval]))",
          "legendFormat": "{{action}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": { "mode": "normal", "group": "A" }
          }
        }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Injection Guardrails (G30)",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Injections blocked",
      "description": "Total prompt-injection / jailbreak attempts blocked (action=block) over the selected time range.",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 3 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(token_opt_guardrail_events_total{tenant_id=~\"$tenant\",action=\"block\"}[$__range])) or vector(0)",
          "legendFormat": "blocks"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "text": { "valueSize": 36 }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Attempts flagged",
      "description": "Total guardrail events flagged (action=flag) over the selected time range.",
      "gridPos": { "x": 0, "y": 11, "w": 6, "h": 3 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(token_opt_guardrail_events_total{tenant_id=~\"$tenant\",action=\"flag\"}[$__range])) or vector(0)",
          "legendFormat": "flagged"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "text": { "valueSize": 28 }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Guardrail events by attack category",
      "gridPos": { "x": 6, "y": 8, "w": 10, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (category) (increase(token_opt_guardrail_events_total{tenant_id=~\"$tenant\"}[$__rate_interval]))",
          "legendFormat": "{{category}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": { "mode": "normal", "group": "A" }
          }
        }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Guardrail events by action (flag vs block)",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (action) (increase(token_opt_guardrail_events_total{tenant_id=~\"$tenant\"}[$__rate_interval]))",
          "legendFormat": "{{action}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": { "mode": "normal", "group": "A" }
          }
        }
      }
    }
  ]
}
