{
  "title": "Token Optimisation - Pitch Comparison",
  "uid": "token-opt-pitch",
  "tags": [
    "token-optimisation",
    "pitch"
  ],
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Simple — FAQ Bot % Reduction",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 3
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG((metadata->>'total_pct_saving')::float)::numeric,1) AS pct_reduction FROM traces WHERE ('${tenant}' = '.*' OR metadata->>'tenant_id' = '${tenant}') AND metadata->>'user_id' = 'pitch-optimized@pitch.test' AND metadata->>'complexity_tier' = 'simple'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "yellow",
                "value": 0
              },
              {
                "color": "green",
                "value": 20
              }
            ]
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": {
                  "text": "No runs",
                  "index": 0
                }
              }
            }
          ]
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "text": {
          "titleSize": 17,
          "valueSize": 30
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Medium — Doc Q&A % Reduction",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 3
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG((metadata->>'total_pct_saving')::float)::numeric,1) AS pct_reduction FROM traces WHERE ('${tenant}' = '.*' OR metadata->>'tenant_id' = '${tenant}') AND metadata->>'user_id' = 'pitch-optimized@pitch.test' AND metadata->>'complexity_tier' = 'medium'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "yellow",
                "value": 0
              },
              {
                "color": "green",
                "value": 25
              }
            ]
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": {
                  "text": "No runs",
                  "index": 0
                }
              }
            }
          ]
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "text": {
          "titleSize": 17,
          "valueSize": 30
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Complex — Code Agent % Reduction",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 3
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG((metadata->>'total_pct_saving')::float)::numeric,1) AS pct_reduction FROM traces WHERE ('${tenant}' = '.*' OR metadata->>'tenant_id' = '${tenant}') AND metadata->>'user_id' = 'pitch-optimized@pitch.test' AND metadata->>'complexity_tier' = 'complex'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {
                "color": "yellow",
                "value": 0
              },
              {
                "color": "green",
                "value": 30
              }
            ]
          },
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": {
                  "text": "No runs",
                  "index": 0
                }
              }
            }
          ]
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "text": {
          "titleSize": 17,
          "valueSize": 30
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Cost Saved",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 3,
        "h": 3
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(SUM((metadata->>'cost_saving_usd')::float)::numeric,6) FROM traces WHERE metadata->>'user_id' = 'pitch-optimized@pitch.test'",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "mappings": [
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": {
                  "text": "No runs",
                  "index": 0
                }
              }
            }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "text": {
          "titleSize": 15,
          "valueSize": 22
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Cache Hits",
      "gridPos": {
        "x": 15,
        "y": 0,
        "w": 3,
        "h": 3
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) FROM traces WHERE metadata->>'user_id' = 'pitch-optimized@pitch.test' AND (metadata->>'cache_hit')::boolean = true",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "text": {
          "titleSize": 15,
          "valueSize": 22
        }
      }
    },
    {
      "id": 4,
      "type": "barchart",
      "title": "Baseline vs Optimized — Tokens per Run",
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 10,
        "h": 7
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT metadata->>'user_id' AS run_type, ROUND(AVG((metadata->>'baseline_tokens')::float)) AS avg_baseline_tokens, ROUND(AVG((metadata->>'final_tokens_sent')::float)) AS avg_final_tokens FROM traces WHERE metadata->>'user_id' IN ('pitch-baseline@pitch.test','pitch-optimized@pitch.test') GROUP BY 1 ORDER BY 1",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "axisLabel": "",
            "lineWidth": 1,
            "fillOpacity": 80
          }
        }
      },
      "options": {
        "barWidth": 0.35,
        "groupWidth": 0.5,
        "showValue": "always",
        "orientation": "auto",
        "legend": {
          "showLegend": true,
          "placement": "bottom",
          "displayMode": "list"
        },
        "text": {
          "valueSize": 14
        }
      }
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "G-Group Savings Contribution (Tokens)",
      "gridPos": {
        "x": 10,
        "y": 3,
        "w": 14,
        "h": 7
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT key AS g_group, SUM((value->>'abs_saving')::int) AS tokens_saved FROM traces, jsonb_each(metadata->'step_savings') WHERE metadata->>'user_id' = 'pitch-optimized@pitch.test' AND (value->>'abs_saving')::int > 0 GROUP BY 1 ORDER BY tokens_saved DESC",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "axisLabel": "",
            "lineWidth": 1,
            "fillOpacity": 80
          }
        }
      },
      "options": {
        "barWidth": 0.4,
        "showValue": "always",
        "orientation": "auto",
        "legend": {
          "showLegend": false
        },
        "text": {
          "valueSize": 14
        }
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Per-Step Breakdown — Latest Optimized Runs",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT id AS request_id, created_at::time(0) AS time, metadata->>'model_requested' AS model, (metadata->>'baseline_tokens')::int AS baseline, (metadata->>'final_tokens_sent')::int AS final, ROUND((metadata->>'total_pct_saving')::numeric,1) AS pct_saving, ROUND((metadata->>'cost_saving_usd')::numeric,6) AS cost_saved FROM traces WHERE metadata->>'user_id' = 'pitch-optimized@pitch.test' ORDER BY created_at DESC LIMIT 10",
          "format": "table"
        }
      ],
      "options": {
        "cellHeight": "md"
      }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Waterfall — Step Savings per Optimized Call",
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT t.id AS request_id, t.metadata->>'model_requested' AS model, s.key AS g_group, (s.value->>'abs_saving')::int AS tokens_saved, ROUND((s.value->>'pct_saving_vs_baseline')::numeric,1) AS pct_of_baseline, s.value->>'description' AS description FROM traces t, jsonb_each(t.metadata->'step_savings') s WHERE t.metadata->>'user_id' = 'pitch-optimized@pitch.test' AND (s.value->>'abs_saving')::int > 0 ORDER BY t.created_at DESC, s.key",
          "format": "table"
        }
      ],
      "options": {
        "cellHeight": "md"
      }
    },
    {
      "id": 10,
      "type": "table",
      "title": "Side-by-Side — Last 6 Runs (Baseline + Optimized)",
      "gridPos": {
        "x": 0,
        "y": 18,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "uid": "langfuse-postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT metadata->>'user_id' AS run_type, created_at, metadata->>'model_requested' AS model, (metadata->>'baseline_tokens')::int AS baseline_tokens, (metadata->>'final_tokens_sent')::int AS final_tokens, ROUND((metadata->>'total_pct_saving')::numeric,1) AS pct_saving, ROUND((metadata->>'cost_saving_usd')::numeric,6) AS cost_saved_usd, (metadata->>'cache_hit')::boolean AS cache_hit, metadata->>'routed_model' AS routed_model FROM traces WHERE metadata->>'user_id' IN ('pitch-baseline@pitch.test','pitch-optimized@pitch.test') ORDER BY created_at DESC LIMIT 6",
          "format": "table"
        }
      ],
      "options": {
        "cellHeight": "md"
      }
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "Pitch Test Runs",
        "datasource": {
          "uid": "langfuse-postgres"
        },
        "rawQuery": "SELECT created_at AS time, (metadata->>'user_id') || ' - ' || metadata->>'model_requested' AS text FROM traces WHERE metadata->>'user_id' IN ('pitch-baseline@pitch.test','pitch-optimized@pitch.test') ORDER BY created_at",
        "enable": true,
        "iconColor": "blue"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "label": "Tenant",
        "datasource": {
          "uid": "prometheus"
        },
        "definition": "label_values(token_opt_requests_total, tenant_id)",
        "query": "label_values(token_opt_requests_total, tenant_id)",
        "includeAll": true,
        "multi": false,
        "allValue": ".*",
        "current": {
          "value": "$__all",
          "text": "All"
        },
        "refresh": 2
      }
    ]
  }
}
