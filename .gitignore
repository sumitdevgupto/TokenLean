# ─── Commercial layer (private — open-core split) ────────────────────────────
# Pure-commercial source (item 8). Engines STAY in core (billing/metering.py,
# billing/models.py, audit/, tenancy/) — only tier-gating + portal + gdpr gated.
src/proxy/api/portal.py
src/proxy/api/gdpr.py
# Multi-tenant management console API (H2) — tenant lifecycle over HTTP (create/suspend/
# delete/list + pricing + invoice run). The key-store WRITE engine stays core+unwired
# (auth/api_key_manager.py); THIS router is the commercial product that exposes it.
src/proxy/api/admin.py
# Portal customer auth + self-serve onboarding (email+password, Redis sessions, signup/
# verify/reset, auto tenant provisioning). Commercial — depends on bcrypt (commercial
# image only) and is imported only by commercial_app.py / api/admin.py.
src/proxy/api/portal_auth.py
# Transactional email sender (SendGrid v3 via httpx) for verification + reset emails.
src/proxy/api/email_sender.py
# Per-tenant BYOK provider-key store (Fernet-encrypted). Commercial — depends on
# cryptography (commercial image only); imported by commercial_app.py.
src/proxy/api/tenant_keys.py
# Operator-console auth (email+bcrypt, own session/cookie, out-of-band provisioning, NO
# signup) — gates the /adminconsole operator surface. Commercial; imported only by
# commercial_app.py.
src/proxy/api/operator_auth.py
# Per-tenant GCS doc-bucket provisioner (create bucket + OBJECT_FINALIZE notification +
# objectViewer grant) invoked at onboarding, and the signed-upload-URL router. Commercial —
# depend on google-cloud-storage (commercial image only); imported by commercial_app.py /
# api/portal_auth.py. The bucket<->tenant naming helpers stay in core (tenancy/context.py).
src/proxy/api/tenant_provisioning.py
src/proxy/api/upload.py
# Enterprise Docs RAG-chat endpoint + its shared cross-tenant answer cache (commercial).
src/proxy/api/docs.py
src/proxy/api/docs_cache.py
# Transient build-staging dir: the deploy scripts copy the docs-seeder + docs snapshot here
# right before the commercial image build (Dockerfile.commercial COPYs it to /app/seed). Never
# committed — it's regenerated each build.
src/proxy/_docs_seed/
src/proxy/billing/tiers.py
# Request-count invoicing (E2) — the paid product's billing calculation. Engines
# (metering/models/audit) stay in core; the invoice generator is commercial.
src/proxy/billing/invoicing.py
# Payment-push seam (H1) — the Stripe integration point. Commercial.
src/proxy/billing/payments.py
# SOC2 / audit-attestation tooling (I1) — paid product. The OSS audit ENGINE
# (audit/log.py) stays core; only this attestation tooling is commercial.
src/proxy/audit/attestation.py
tests/test_attestation.py
# Managed red-team ruleset feed (#3) — commercial. The OSS G30 scanner + default
# ruleset stay in core (guardrails/injection.py, guardrails/pii.py, guardrails/__init__.py).
src/proxy/guardrails/ruleset_feed.py
tests/test_ruleset_feed.py
# Commercial app entrypoint — wires the gated GDPR/portal/billing routers (item 26).
