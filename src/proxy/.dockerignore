# ─── Commercial layer — excluded from the OSS proxy image (item 19) ───────────
# The proxy build context is ./src/proxy and the Dockerfile does `COPY . .`, so
# these commercial-layer modules must be excluded from the free image. Mirrors
# the commercial .gitignore. Engines STAY in the image: billing/metering.py,
# billing/models.py, billing/api.py, audit/, tenancy/.
api/portal.py
api/portal_auth.py
api/email_sender.py
api/tenant_keys.py
api/operator_auth.py
api/gdpr.py
api/admin.py
api/docs.py
api/docs_cache.py
# Docs-seeder + docs snapshot staged for the COMMERCIAL image only — the OSS image must not
# carry enterprise docs. (Dockerfile.commercial.dockerignore does NOT strip this, so the paid
# image keeps it.)
_docs_seed/
commercial_app.py
billing/tiers.py
billing/invoicing.py
billing/payments.py
audit/attestation.py
# Managed red-team ruleset feed (#3) — commercial; the OSS G30 scanner + default
# ruleset stay in the image (guardrails/injection.py, guardrails/pii.py).
guardrails/ruleset_feed.py
# Agentic learning loop (F1) — commercial; feeds G24/G20 via config/Redis, core never imports it.
learning/

# ─── Build hygiene ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
